# Retail kiosk systemd environment template
# Copy to /etc/retail-kiosk/kiosk.env and edit per device.
# Do not commit real device credentials or secrets.

KIOSK_ID=hq-001
LOCATION_ID=hq
# kiosk-agent accepts both legacy template aliases and explicit KIOSK_* names.
KIOSK_LOCATION_ID=hq
KIOSK_APP_DIR=/opt/retail-kiosk/current
KIOSK_PREVIOUS_DIR=/opt/retail-kiosk/previous
KIOSK_DATA_DIR=/var/lib/retail-kiosk
KIOSK_LOG_DIR=/var/log/retail-kiosk
KIOSK_CONFIG_DIR=/etc/retail-kiosk

LOCAL_BACKEND_HOST=127.0.0.1
LOCAL_BACKEND_PORT=8787
LOCAL_RUNTIME_URL=http://127.0.0.1:8787
PLAYER_STATIC_DIR=/opt/retail-kiosk/current/apps/kiosk-player/dist
ADMIN_STATIC_DIR=/opt/retail-kiosk/current/apps/admin-dashboard/dist-web
SQLITE_PATH=/var/lib/retail-kiosk/runtime.sqlite
PACKAGE_CACHE_PATH=/var/lib/retail-kiosk/packages
DEVICE_CREDENTIAL_PATH=/etc/retail-kiosk/device-credential.json
HARDWARE_MODE=fake
TOKEN_ADAPTER=fake
TOKEN_SERIAL_PORT=/dev/retail-kiosk-token
TOKEN_SERIAL_BAUD=9600
PRINTER_ADAPTER=fake
PRINTER_NAME=PT80KM
PAPER_PROFILE=80mm

PLAYER_ORIGIN=http://127.0.0.1:8787/player
KIOSK_BROWSER_BIN=/usr/bin/chromium-browser
KIOSK_BROWSER_FLAGS="--kiosk --noerrdialogs --disable-infobars --disable-session-crashed-bubble --check-for-update-interval=31536000"
DISPLAY=:0
XAUTHORITY=/home/kiosk/.Xauthority

CENTRAL_API_URL=https://control.example.invalid
CENTRAL_API_BASE_URL=https://control.example.invalid
HEARTBEAT_INTERVAL_SECONDS=30
KIOSK_AGENT_POLL_INTERVAL_MS=30000
EVENT_UPLOAD_INTERVAL_SECONDS=30
LOG_RETENTION_DAYS=14
MIN_FREE_DISK_MB=1024
