{
  "name": "@retail-kiosk/kiosk-player",
  "version": "0.0.0",
  "description": "Svelte/Vite fullscreen kiosk player for the local runtime.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.build.json && vite build",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "NODE_OPTIONS=--conditions=browser node --test test/*.test.mjs"
  },
  "dependencies": {
    "@retail-kiosk/shared-types": "workspace:*",
    "@sveltejs/vite-plugin-svelte": "latest",
    "svelte": "latest",
    "typescript": "^5.9.3",
    "vite": "latest"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "svelte-check": "latest"
  },
  "private": true
}
