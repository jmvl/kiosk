{
  "name": "@retail-kiosk/campaign-schema",
  "version": "0.0.0",
  "description": "Activation package manifest schema and validator.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "retail-kiosk-package-validate": "scripts/validate-manifest.mjs"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && node --test test/*.test.mjs",
    "package:validate": "pnpm build && node scripts/validate-manifest.mjs ../../campaigns/chocomel/manifest.json --root ../../campaigns/chocomel"
  }
}
